		"typecheck": "tsc --noEmit",
		"version:bump": "bun scripts/version-bump.ts"
	},
	"dependencies": {
		"chalk": "^5.6.2",
		"commander": "^14.0.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.15",
		"@types/bun": "latest",
		"typescript": "^5.9.0"
	},
	"optionalDependencies": {
		"@anthropic-ai/sdk": "^0.39.0"
	}
}
